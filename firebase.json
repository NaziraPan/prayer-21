{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "target": "checkin",
      "public": "dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "revelations",
      "public": "dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "destination": "/revelations.html"
        }
      ]
    }
  ]
}
